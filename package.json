{
  "name": "rasikawan-portfolio",
  "version": "0.1.0",
  "description": "Multi-tenant child portfolio platform with admin management",
  "private": true,
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node db/migrate.js",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm install && npm run build",
    "push": "bash scripts/push.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "multer": "^2.0.0",
    "pg": "^8.12.0",
    "unzipper": "^0.12.3",
    "vary": "^1.1.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
