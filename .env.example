# --- Server ---
PORT=3000
NODE_ENV=development
# Base apex domain. Subdomains under this are treated as tenants.
# Example: rasikawan.com -> kong.rasikawan.com loads child "kong"
ROOT_DOMAIN=rasikawan.com
# Optional dev shim. When set, requests to localhost are treated as if they
# came from this subdomain (handy without /etc/hosts editing).
DEV_FORCE_SUBDOMAIN=

# --- PostgreSQL ---
PGHOST=103.40.118.129
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=portfolio_db

# --- Sessions ---
# Long random string. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
# Cookie domain so the admin session is scoped to admin.<ROOT_DOMAIN> only.
# Leave blank in dev to default to current host.
SESSION_COOKIE_DOMAIN=

# --- Bootstrap admin (created on first migrate if missing) ---
BOOTSTRAP_ADMIN_EMAIL=admin@rasikawan.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# --- YouTube Data API (optional) ---
# When set, the portfolio fetches live channel stats + the latest N videos for
# any child whose YouTube section has a `handle` (e.g. @kong-adventures).
# Without a key, the renderer falls back to whatever the admin typed in.
# Get a key at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# --- Anthropic API (optional) ---
# Powers the admin's "Auto-fill from file" button on Awards and Certificates.
# When set, uploaded award/certificate images and PDFs are sent to Claude to
# extract title, year, issuer, and rank — the form pre-fills with the result.
# Without a key the button is hidden and admins fill the fields manually.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
